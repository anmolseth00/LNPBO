    "random"
  ],
  "seeds": [42, 123, 456, 789, 2024],
  "feature_type": "lantern_il_only",
  "normalize": "copula",
  "reduction": "pca",
  "n_pcs": 5,
  "seed_fraction": 0.25,
  "max_oracle_fraction": 0.5,
  "metrics": [
    "top_k_recall_5pct",
    "top_k_recall_10pct",
    "top_k_recall_20pct",
    "auc"
  ],
  "experiment_name": "small_study_benchmark"
}
