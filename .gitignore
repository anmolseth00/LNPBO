# ==========================
# Python
# ==========================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ==========================
# Virtual environments
# ==========================
.venv/
venv/
env/
ENV/

# ==========================
# IDE / Editor
# ==========================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# ==========================
# OS generated files
# ==========================
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
.Spotlight-V100
.Trashes

# ==========================
# Jupyter Notebook
# ==========================
.ipynb_checkpoints/

# ==========================
# Pipeline outputs (generated at runtime)
# ==========================
pipeline_output.csv
pipeline_encodings.csv
round_*_gp.pkl

# ==========================
# Lock / temp files
# ==========================
.~lock.*
*.lock
!uv.lock
!poetry.lock

# ==========================
# Logs
# ==========================
*.log

# ==========================
# TensorBoard / training artifacts
# ==========================
events.out.tfevents.*

# ==========================
# Large model binaries
# ==========================
*.pt
*.pkl
*.joblib
*.npy
*.npz

# ==========================
# Symlinks to external repos
# ==========================
data/LNPDB_repo

# ==========================
# Embedding / descriptor caches (large binary files)
# ==========================
data/chemeleon_cache/
data/mordred_cache/
data/rdkit_cache/
data/unimol_cache/

# ==========================
# Benchmark results
# ==========================
benchmark_results/

# ==========================
# Generated reports (regenerable from scripts)
# ==========================
experiments/data_integrity/stratification_report.json
experiments/data_integrity/stratification_report.md
experiments/data_integrity/data_landscape.json
diagnostics/*.json
diagnostics/*.png

# ==========================
# Paper (LaTeX source, managed separately)
# ==========================
# Ignore manuscript sources/build artifacts and figure outputs, but keep the
# figure-generation scripts under version control so the figure pipeline is
# reproducible from a fresh clone.
paper/*
!paper/*.py

# ==========================
# MkDocs build output
# ==========================
site/

# ==========================
# Ad-hoc launcher scripts (not scripts/run_parallel.sh)
# ==========================
/run_*.sh

# ==========================
# Claude Code
# ==========================
.claude/

# ==========================
# NOTE: The following are intentionally NOT ignored:
#   - examples/       (example notebooks, CSVs, and data)
#   - data/           (LiON model checkpoints, templates, bridge code)
#   - benchmarks/     (benchmark package)
#   - LNPBO.png       (repo diagram)
#   - LICENSE, README.md
# ==========================

# ==========================
# Large files (keep local, don't track)
# ==========================
LNPDB.pdf
experiments/analysis/figures/
experiments/analysis/_archive/
experiments/data_integrity/figures/

# ==========================
# Local-only data drops / archives (collaborator results, caches, scratch)
# Never commit these — regenerable or transferred out-of-band.
# ==========================
*.tar
*.tar.gz
*.zip
lnpbo_caches.tar
tmp/
tmp*.png
logs/
# macOS AppleDouble / resource-fork junk (appears in transferred folders)
._*
