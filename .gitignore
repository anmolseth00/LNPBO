# ==========================
# Python
# ==========================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ==========================
# Virtual environments
# ==========================
.venv/
venv/
env/
ENV/

# ==========================
# IDE / Editor
# ==========================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# ==========================
# OS generated files
# ==========================
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
.Spotlight-V100
.Trashes

# ==========================
# Jupyter Notebook
# ==========================
.ipynb_checkpoints/

# ==========================
# Pipeline outputs (generated at runtime)
# ==========================
pipeline_output.csv
pipeline_encodings.csv
round_*_gp.pkl
benchmark_*.json
benchmark_*.png

# ==========================
# Lock / temp files
# ==========================
.~lock.*
*.lock
!uv.lock
!poetry.lock

# ==========================
# Logs
# ==========================
*.log

# ==========================
# TensorBoard / training artifacts
# ==========================
events.out.tfevents.*

# ==========================
# Large model binaries (tracked via results JSON instead)
# ==========================
*.pt
*.joblib
models/runs/*/model.json
*.npy

# ==========================
# Symlinks to external repos
# ==========================
data/LNPDB_repo

# ==========================
# Embedding / descriptor caches (large binary files)
# ==========================
data/chemeleon_cache/
data/mordred_cache/

# ==========================
# Benchmark results (only clean-data results are tracked)
# ==========================
benchmark_results/*
!benchmark_results/clean_*

# ==========================
# Generated outputs
# ==========================
proposed_ils.csv
shap_output/
slides/
generative/

# ==========================
# Claude Code
# ==========================
.claude/

# ==========================
# Benchmark package (not ignored -- replaces benchmark.py)
# ==========================
!benchmarks/
!benchmarks/*.py

# ==========================
# NOTE: The following are intentionally NOT ignored:
#   - examples/       (example notebooks, CSVs, and data)
#   - data/           (LiON model checkpoints, templates, bridge code)
#   - LNPBO.png       (repo diagram)
#   - LICENSE, README.md
#
# If example round_*_gp.pkl or example *_encodings.csv files
# should be kept in the repo, you can override with:
#   !examples/**/round_*_gp.pkl
#   !examples/**/*_encodings.csv
# ==========================
